# ────────────────────────────────────────────────────────────────
# SOURCE — UrbanPiper ClickHouse (read-only)
# ────────────────────────────────────────────────────────────────
SOURCE_HOST=cfi-data-secure.urbanpiper.com
SOURCE_PORT=8123
SOURCE_USER=curefoods
SOURCE_PASSWORD=your_source_password_here

# ────────────────────────────────────────────────────────────────
# LOCAL DESTINATION — ClickHouse in Docker
# ────────────────────────────────────────────────────────────────
LOCAL_HOST=localhost
LOCAL_PORT=8123
LOCAL_USER=default
LOCAL_PASSWORD=admin123
LOCAL_DB=demand_planning

# ────────────────────────────────────────────────────────────────
# SUPPLYNOTE API
# ────────────────────────────────────────────────────────────────
SUPPLYNOTE_BASE_URL=https://app.supplynote.com
SUPPLYNOTE_EMAIL=your_email@curefoods.com
SUPPLYNOTE_PASSWORD=your_supplynote_password
SUPPLYNOTE_TOKEN=Bearer eyJ...your_captured_bearer_token

# ────────────────────────────────────────────────────────────────
# SUPABASE (Auth + User management)
# ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=eyJxxx...your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...your_service_role_key

# ────────────────────────────────────────────────────────────────
# APP SETTINGS
# ────────────────────────────────────────────────────────────────
# Set to "true" to use dummy data when source connections fail
USE_DUMMY_DATA=false
# Demo mode bypasses auth (local dev only)
DEMO_MODE=false
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Timezone
TZ=Asia/Kolkata
